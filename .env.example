# MSU Vendor Portal — environment variables
# Copy to .env and fill in values. Never commit .env.

# --- Database (Postgres 16) ---
# Application connection (vendor_app_role — least privilege).
PGHOST=localhost
PGPORT=5432
PGDATABASE=msu_wallet
PGUSER=vendor_app_role
PGPASSWORD=change_me_app

# Migration connection (admin_migration_role — only used by db:migrate / db:seed).
PG_ADMIN_USER=admin_migration_role
PG_ADMIN_PASSWORD=change_me_admin

# Bootstrap superuser (used once by docker-compose to create the two roles above).
POSTGRES_PASSWORD=change_me_super

# --- Crypto ---
# 32-byte hex (generate with: openssl rand -hex 32)
MASTER_KEY=replace_with_openssl_rand_hex_32

# --- Session ---
SESSION_SECRET=replace_with_openssl_rand_hex_32

# --- Server ---
HTTPS_PORT=3443
TLS_KEY_PATH=./certs/server.key
TLS_CERT_PATH=./certs/server.cert

# --- App ---
NODE_ENV=development
MFA_ISSUER=MSU Akan Wallet
MFA_WINDOW_MINUTES=5
